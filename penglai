#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""penglai — 蓬莱助手发行版唯一入口（基于 GenericAgent，内核零改动）。

用法:
  penglai           直接对话（终端 TUI，等价上游 GA 的 tuiapp_v2）
  penglai doctor    体检：环境/依赖/配置/服务/记忆/上游状态
  penglai status    服务状态
  penglai start     启动服务（飞书 + 调度器）
  penglai stop      停止服务
  penglai logs [渠道]  查看最近日志（默认飞书）
  penglai channels  IM 渠道矩阵总览（飞书/微信/钉钉/企微/QQ/Telegram/Discord）
  penglai enable <渠道>   启用渠道（钉钉/QQ 支持扫码自动建应用）
  penglai disable <渠道>  停用渠道
  penglai update    更新到最新版蓬莱发行仓
  penglai setup     安装向导（语言 → 依赖 → 模型 → 渠道单页选择 → 能力面板[语音/陪伴/情报]）
  penglai help      显示本帮助
"""
import os, sys, shutil, subprocess

# realpath 而非 abspath：install.sh 会软链 ~/.local/bin/penglai → 仓库内本体，
# abspath 会把 ROOT 解析到 ~/.local/bin，整个发行版找不到自己（真机踩过）
ROOT = os.path.dirname(os.path.realpath(__file__))
SERVICES = ["penglai-feishu", "penglai-scheduler", "penglai-companion", "penglai-wechat",
            "penglai-dingtalk", "penglai-wecom2", "penglai-qq", "penglai-telegram", "penglai-discord"]
OPTIN_SERVICES = {"penglai-companion": "主动陪伴", "penglai-wechat": "微信渠道",
                  "penglai-dingtalk": "钉钉渠道", "penglai-wecom2": "企业微信渠道",
                  "penglai-qq": "QQ渠道", "penglai-telegram": "Telegram渠道",
                  "penglai-discord": "Discord渠道"}  # 未装≠故障
# 服务未启用时，doctor 直接给出"怎么开"的命令（发现→开启闭环）
SVC_ENABLE = {"penglai-companion": "penglai enable companion", "penglai-wechat": "penglai setup",
              "penglai-dingtalk": "penglai enable dingtalk", "penglai-wecom2": "penglai enable wecom",
              "penglai-qq": "penglai enable qq", "penglai-telegram": "penglai enable telegram",
              "penglai-discord": "penglai enable discord"}
OK, BAD, WARN = "✅", "❌", "⚠️ "

def sh(cmd, **kw):
    return subprocess.run(cmd, capture_output=True, text=True, **kw)

def venv_python():
    p = os.path.join(ROOT, ".venv", "bin", "python")
    return p if os.path.exists(p) else sys.executable

def has_systemd():
    return shutil.which("systemctl") is not None

# ---------- 无 systemd 环境（容器/macOS）的进程管理 ----------
FSLOG = os.path.join(ROOT, "temp", "fsapp.log")

def fsapp_pids():
    r = sh(["pgrep", "-f", "frontends/fsapp.py"])
    return [int(x) for x in r.stdout.split()] if r.returncode == 0 else []

def fsapp_start():
    import time
    if pids := fsapp_pids():
        print(f"{OK} 飞书进程已在运行（PID {pids[0]}）"); return 0
    os.makedirs(os.path.join(ROOT, "temp"), exist_ok=True)
    lf = open(FSLOG, "ab")
    p = subprocess.Popen([venv_python(), os.path.join(ROOT, "frontends", "fsapp.py")], cwd=ROOT,
                         stdout=lf, stderr=subprocess.STDOUT, stdin=subprocess.DEVNULL,
                         start_new_session=True)
    deadline = time.monotonic() + 45
    while time.monotonic() < deadline:
        if p.poll() is not None:
            print(f"{BAD} 进程退出（码 {p.returncode}），最近日志：")
            for l in open(FSLOG, encoding="utf-8", errors="replace").read().splitlines()[-8:]:
                print("  " + l[:160])
            return 1
        with open(FSLOG, encoding="utf-8", errors="replace") as f:
            if "connected to wss" in f.read():
                print(f"{OK} 飞书进程已启动且长连接已建立（PID {p.pid}，日志: penglai logs）")
                return 0
        time.sleep(2)
    print(f"{WARN}进程在跑（PID {p.pid}）但 45 秒未见连接成功，penglai logs 查看")
    return 1

def fsapp_stop():
    import signal
    pids = fsapp_pids()
    if not pids:
        print(f"{OK} 飞书进程未在运行"); return 0
    for pid in pids:
        try: os.kill(pid, signal.SIGTERM)
        except ProcessLookupError: pass
    print(f"{OK} 已停止（PID {' '.join(map(str, pids))}）"); return 0

def installed_services():
    """只返回真正装了 unit 文件的服务（companion 是 opt-in，可能没装）。"""
    out = []
    for s in SERVICES:
        if sh(["systemctl", "list-unit-files", f"{s}.service"]).stdout.strip().count(s):
            out.append(s)
    return out or SERVICES[:2]

# ---------- 安全插件预检（F-011 把静默 fail-open 变成可检测/阻断）----------
GUARD_PLUGINS = ["plugins.penglai_redline", "plugins.penglai_memguard", "plugins.penglai_fileguard"]

def guardcheck():
    """验证安全插件（红线/记忆卫生/文件外发）真正 import 且挂载到 GenericAgentHandler。
    供 doctor / start / 容器入口 / systemd 单元统一复用。0=已挂载 1=未挂载。
    机制：discover_and_load 对失败插件 except:pass（fail-open），故启动前必须主动核验，
    否则 agent 可能在【无任何防护】下运行而无人知晓。"""
    try:
        sys.path.insert(0, ROOT)
        import plugins.hooks as h
        h.discover_and_load()
        import ga
        miss = [m for m in GUARD_PLUGINS if m not in sys.modules]
        cr = ga.GenericAgentHandler.do_code_run.__module__
        fw = ga.GenericAgentHandler.do_file_write.__module__
        fg_ok = _probe_fileguard_mount()
    except Exception as e:
        print(f"FAIL import-error: {e}"); return 1
    if not miss and cr != "ga" and fw != "ga" and fg_ok:
        print("OK 安全插件已挂载（红线/记忆卫生/文件外发）"); return 0
    print(f"FAIL 未挂载 missing={miss} code_run={cr} file_write={fw} fileguard={fg_ok}"); return 1

def _probe_fileguard_mount():
    """模拟生产部署的真实路径：fsapp 以 `python frontends/fsapp.py` 跑时模块名是
    __main__。曾因 fileguard 只查 frontends.fsapp 在生产静默 fail-open 而 guardcheck
    假绿（2026-06-11 真机事故），此探针专门复现该形态，挂不上=FAIL。"""
    import types
    import plugins.penglai_fileguard as fg
    fake = types.ModuleType("__main__")
    fake.__file__ = os.path.join(ROOT, "frontends", "fsapp.py")
    fake._send_local_file = lambda *a, **k: True
    fake.send_message = lambda *a, **k: None
    saved_main = sys.modules.get("__main__")
    saved = (fg._PATCHED, fg._orig_send_local_file, fg._fsapp_mod)
    try:
        fg._PATCHED, fg._orig_send_local_file, fg._fsapp_mod = False, None, None
        sys.modules["__main__"] = fake
        mounted = fg._try_patch()
        wrapped = fake._send_local_file is fg._guarded_send_local_file
        return bool(mounted and wrapped)
    finally:
        if saved_main is not None:
            sys.modules["__main__"] = saved_main
        fg._PATCHED, fg._orig_send_local_file, fg._fsapp_mod = saved

def guard_ok():
    """以 venv python 子进程跑 guardcheck，返回 (ok, 末行详情)。doctor/start 复用。"""
    r = sh([venv_python(), os.path.join(ROOT, "penglai"), "_guardcheck"], cwd=ROOT)
    lines = (r.stdout or "").strip().splitlines()
    last = lines[-1] if lines else ((r.stderr or "").strip().splitlines() or [""])[-1]
    return (r.returncode == 0 and last.startswith("OK")), last

# ---------- doctor ----------
def doctor():
    print("🏮 蓬莱医生体检中...\n")
    bad = 0

    def check(name, ok, hint=""):
        nonlocal bad
        print(f"{OK if ok else BAD} {name}" + ("" if ok else f"   → {hint}"))
        if not ok: bad += 1

    # 1. Python
    v = sys.version_info
    check(f"Python {v.major}.{v.minor}", v >= (3, 10), "需要 Python 3.10+")

    # 2. venv 与核心依赖
    py = venv_python()
    r = sh([py, "-c", "import requests, bs4, aiohttp, bottle"])
    check("核心依赖 (requests/bs4/aiohttp/bottle)", r.returncode == 0,
          "运行: uv pip install --python .venv/bin/python -e .")
    r = sh([py, "-c", "import lark_oapi"])
    check("飞书 SDK (lark-oapi)", r.returncode == 0,
          "运行: uv pip install --python .venv/bin/python lark-oapi")

    # 2b. 微信绑定（可选渠道，未绑定≠故障）
    tok = os.path.expanduser("~/.wxbot/token.json")
    if os.path.exists(tok):
        try:
            import json
            bid = json.load(open(tok, encoding="utf-8")).get("ilink_bot_id", "")
            print(f"{OK} 微信绑定：{bid or '已有 token'}")
        except Exception:
            print(f"{WARN} 微信 token 文件损坏 → 重跑 penglai setup 扫码")
        if has_systemd() and sh(["systemctl", "show", "penglai-wechat",
                                 "-p", "ExecMainStatus", "--value"]).stdout.strip() == "2":
            print(f"{WARN} 微信 token 已过期 → penglai setup 重新扫码后 sudo systemctl restart penglai-wechat")
    else:
        print(f"{OK} 微信：未绑定（可选渠道，penglai setup 可扫码接入）")

    # 2c. 语音能力（可选；引擎+模型+ffmpeg 三件套齐了才报就绪，装一半要提示）
    _mdir = os.path.join(os.environ.get("PENGLAI_MODEL_DIR", os.path.expanduser("~/penglai-models")),
                         "sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17")
    _voice = (("模型", os.path.isfile(os.path.join(_mdir, "model.int8.onnx"))),
              ("sherpa-onnx", sh([py, "-c", "import sherpa_onnx"]).returncode == 0),
              ("ffmpeg", shutil.which("ffmpeg") is not None))
    if all(ok for _, ok in _voice):
        print(f"{OK} 语音：就绪（SenseVoice 本地转写+情绪，含微信 silk）")
    elif not any(ok for _, ok in _voice[:2]):
        print(f"{OK} 语音：未启用（可选能力）   → 开启：penglai enable voice")
    else:
        print(f"{WARN} 语音：装了一半，缺 {'/'.join(n for n, ok in _voice if not ok)}"
              f" → 补齐：penglai enable voice")

    # 3. 配置
    mykey = os.path.join(ROOT, "mykey.py")
    if os.path.exists(mykey):
        r = sh([py, "-c",
                "import mykey;cs=[k for k in dir(mykey) if 'config' in k];"
                "assert cs, 'no config';print(len(cs))"], cwd=ROOT)
        check(f"mykey.py（{r.stdout.strip() or 0} 个配置）", r.returncode == 0,
              "mykey.py 里没有任何 *config*，参考 mykey_template.py")
    else:
        check("mykey.py", False, "复制 mykey_template.py 为 mykey.py 并填入 API Key")

    # 3b. 飞书白名单（空/含* = 对所有可见用户开放本机执行能力，必须红）
    if os.path.exists(mykey):
        r = sh([py, "-c", "import mykey;a=getattr(mykey,'fs_allowed_users',[]);"
                "print('OPEN' if (not a or '*' in a) else 'LOCKED:%d' % len(a))"], cwd=ROOT)
        st = (r.stdout or "").strip()
        if st.startswith("LOCKED"):
            print(f"{OK} 飞书白名单：已收紧（{st.split(':')[1]} 个授权用户）")
        else:
            check("飞书白名单", False,
                  "fs_allowed_users 为空/含*，任何可见用户都能驱动本机 agent！"
                  "填入你的 open_id（penglai logs 里「收到消息 [X]」中的 X），重启服务生效")

    # 4. LLM 连通性（轻量：只验证配置可加载，不真实计费调用）
    r = sh([py, "-c", "from llmcore import *; print('ok')"], cwd=ROOT)
    check("LLM 模块加载 (llmcore)", r.returncode == 0, r.stderr.strip().splitlines()[-1] if r.stderr else "")

    # 4b. 安全插件挂载（红线/记忆卫生/文件外发）—— 未挂载=agent 无防护裸奔，必须红
    ok, detail = guard_ok()
    check("安全插件挂载（红线/记忆卫生/文件外发）", ok,
          f"{detail}！agent 会在无防护下运行，排查 plugins/penglai_*.py 导入错误")

    # 5. 记忆状态（出厂态 or 已使用）
    mem = os.path.join(ROOT, "memory", "global_mem.txt")
    if os.path.exists(mem):
        n = sum(1 for _ in open(mem, encoding="utf-8", errors="replace"))
        print(f"{OK} 记忆 L2：{n} 行（{'出厂态' if n <= 6 else '使用中'}）")
    else:
        print(f"{OK} 记忆 L2：尚未初始化（首次运行自动创建）")

    # 5b. 网页搜索（Bing 免 key 兜底常在；情报矩阵=叠加的增强源）
    r = sh([py, "-c", "import sys;sys.path.insert(0,'.');from plugins.penglai_search import premium_sources;"
            "print(','.join(premium_sources()))"], cwd=ROOT)
    prem = (r.stdout or "").strip()
    print(f"{OK} 网页搜索：{'Bing 免费兜底 + 增强源 ' + prem + '（多源交叉验证）' if prem else 'Bing 免费兜底（开箱即用）   → 增强多源交叉验证：penglai enable intel'}")

    # 5c. 批判脑（绊线免费常开；异厂商复核要配 critic_model）
    r = sh([py, "-c", "import mykey;m=getattr(mykey,'critic_model',None);md=getattr(mykey,'critic_mode','smart');"
            "print('OFF' if md=='off' else ('FULL:'+m.get('model','') if isinstance(m,dict) and m.get('apikey') else 'TRIP'))"], cwd=ROOT)
    st = (r.stdout or "").strip()
    if st.startswith("FULL"):
        print(f"{OK} 批判脑：smart 档（绊线 + 异厂商复核 {st.split(':',1)[1]}）")
    elif st == "OFF":
        print(f"{OK} 批判脑：已关闭（critic_mode=off）   → 开启：penglai enable critic")
    else:
        print(f"{OK} 批判脑：仅本地绊线（免费常开）；异厂商复核未配   → 开启：penglai enable critic")

    # 6. 服务/进程（飞书没在跑 = 机器人收不到消息，必须红）
    if has_systemd():
        inst = installed_services()
        for s in SERVICES:
            if s in OPTIN_SERVICES and s not in inst:
                tip = SVC_ENABLE.get(s, "")
                print(f"{OK} 服务 {s}: 未启用（{OPTIN_SERVICES[s]} opt-in）"
                      + (f" → 开启：{tip}" if tip else ""))
                continue
            r = sh(["systemctl", "is-active", s])
            state = r.stdout.strip()
            if s == "penglai-feishu":
                check(f"服务 {s}: {state or '未安装'}", state == "active", "sudo systemctl restart penglai-feishu")
            else:
                print(f"{OK if state == 'active' else WARN} 服务 {s}: {state or '未安装'}")
    else:
        pids = fsapp_pids()
        check(f"飞书进程（非 systemd 环境，nohup 模式{'，PID ' + str(pids[0]) if pids else ''}）",
              bool(pids), "运行: penglai start")

    # 7. 更新状态（对比发行仓 origin=PenglaiAgent；只读，不改用户的 remote 配置）
    if not is_git_repo():
        print(f"{WARN} 更新检查：压缩包安装无 git 历史，penglai update 不可用（重装即最新）")
    elif sh(["git", "fetch", "origin", "--quiet"], cwd=ROOT).returncode == 0:
        behind = sh(["git", "rev-list", "--count", "HEAD..origin/main"], cwd=ROOT).stdout.strip() or "?"
        mark = OK if behind == "0" else WARN
        print(f"{mark} 蓬莱版本：" + ("已是最新" if behind == "0" else f"落后 {behind} 个提交（penglai update 可更新）"))
    else:
        print(f"{WARN} 更新检查：无法连接发行仓（网络/代理），跳过")

    print(f"\n{'🎉 全部通过，蓬莱身体健康！' if bad == 0 else f'共 {bad} 项需要处理。'}")
    print("   补开能力：penglai abilities ｜ 加 IM 渠道：penglai channels ｜ 重配大模型：penglai setup")
    return 1 if bad else 0

# ---------- services ----------
def svc(action):
    # 启动前 fail-closed：安全插件没挂载就拒绝启动，别让 agent 无防护裸奔（F-011）
    if action in ("start", "restart") and os.environ.get("PENGLAI_ALLOW_UNGUARDED") != "1":
        ok, detail = guard_ok()
        if not ok:
            print(f"{BAD} 安全插件未挂载（{detail}）——为防止 agent 无防护运行，拒绝启动。")
            print("   修复 plugins/penglai_{redline,memguard,fileguard}.py 导入错误后重试，"
                  "或 PENGLAI_ALLOW_UNGUARDED=1 强制启动（危险，不建议）。")
            return 2
    if not has_systemd():
        # 容器/macOS：直接管理 nohup 飞书进程
        if action == "status":
            pids = fsapp_pids()
            print(f"  penglai-feishu: {'running (PID ' + str(pids[0]) + ')' if pids else 'stopped'}")
            return 0
        if action == "start":   return fsapp_start()
        if action == "stop":    return fsapp_stop()
        if action == "restart": fsapp_stop(); return fsapp_start()
    svcs = installed_services()
    if action == "status":
        for s in svcs:
            r = sh(["systemctl", "is-active", s])
            print(f"  {s}: {r.stdout.strip()}")
        return 0
    r = subprocess.run(["sudo", "systemctl", action] + svcs)
    if r.returncode == 0 and action in ("start", "restart"):
        print(f"{OK} 已{('重' if action == 'restart' else '')}启动。penglai logs 可查看日志")
    return r.returncode

def logs():
    ch = sys.argv[2] if len(sys.argv) > 2 else ""
    if ch:  # 指定渠道：penglai logs dingtalk
        import penglai_channels as pc
        if ch not in pc.CHANNELS:
            print(f"可选渠道：{' '.join(pc.CHANNELS)}"); return 1
        if has_systemd():
            return subprocess.run(["journalctl", "-u", pc.CHANNELS[ch]["service"],
                                   "-n", "30", "--no-pager"]).returncode
        lf = pc.logfile(ch)
        if not os.path.exists(lf):
            print(f"{WARN}暂无日志（{lf}）"); return 1
        for l in open(lf, encoding="utf-8", errors="replace").read().splitlines()[-30:]:
            print(l)
        return 0
    if not has_systemd():
        if not os.path.exists(FSLOG):
            print(f"{WARN}暂无日志（{FSLOG}）。先 penglai start"); return 1
        for l in open(FSLOG, encoding="utf-8", errors="replace").read().splitlines()[-30:]:
            print(l)
        return 0
    return subprocess.run(["journalctl", "-u", SERVICES[0], "-n", "30", "--no-pager"]).returncode

# ---------- update（安全自更新：预检 → 后台监工重启 → 健康检查 → 失败自动回滚 → 带外回报）----------
def is_git_repo():
    return sh(["git", "rev-parse", "--is-inside-work-tree"], cwd=ROOT).stdout.strip() == "true"

def _in_docker():
    return os.environ.get("PENGLAI_DOCKER") == "1" or os.path.exists("/.dockerenv")

REINSTALL_HINT = ("curl -fsSL https://raw.githubusercontent.com/"
                  "kevinchennewbee/PenglaiAgent/main/install.sh | sh")
DOCKER_UPDATE_HINT = ("curl -fsSL https://gh-proxy.com/https://raw.githubusercontent.com/"
                      "kevinchennewbee/PenglaiAgent/main/docker-install.sh | sh")
UPDATE_LOG = os.path.join(ROOT, "temp", "update.log")

def _git(*args):
    return sh(["git", *args], cwd=ROOT)

def _fetch_status():
    """返回 (ok, behind, oldsha, newsha, errmsg)。处理浅克隆补全 + ff 可行性。"""
    if not is_git_repo():
        return False, 0, "", "", f"压缩包安装（无 git 历史），无法增量更新。重装即最新：\n   {REINSTALL_HINT}"
    if _git("rev-parse", "--is-shallow-repository").stdout.strip() == "true":
        print("  首次检查：补全 git 历史（浅克隆 → 完整）...")
        _git("fetch", "--unshallow", "origin")
    if _git("fetch", "origin").returncode != 0:
        return False, 0, "", "", "拉取失败（检查网络/代理）"
    old = _git("rev-parse", "HEAD").stdout.strip()
    new = _git("rev-parse", "origin/main").stdout.strip()
    behind = int(_git("rev-list", "--count", "HEAD..origin/main").stdout.strip() or "0")
    return True, behind, old, new, ""

def _changelog(old, new):
    r = _git("log", "--oneline", "--no-decorate", f"{old}..{new}")
    return [l for l in r.stdout.splitlines() if l.strip()]

def _preflight():
    """重启前冒烟：①全仓编译（语法）②安全插件 import+挂载。返回 (ok, detail)。
    新代码连编译/挂载都过不了，就根本不碰正在跑的服务（在杀服务之前拦住坏更新）。"""
    c = sh([venv_python(), "-m", "compileall", "-q", ROOT])
    if c.returncode != 0:
        return False, "编译失败：" + (c.stdout or c.stderr or "")[:200]
    g = sh([venv_python(), os.path.join(ROOT, "penglai"), "_guardcheck"])
    if g.returncode != 0:
        return False, "安全插件挂载失败：" + (g.stdout or "")[:200]
    return True, ""

def update():
    """安全更新到最新版蓬莱发行仓。用法：
       penglai update           交互式：显示更新内容 → 确认 → 安全升级
       penglai update --check   只检查不升级（管家先用这个报告，用户确认后再 --apply）
       penglai update --apply   已确认，直接执行安全升级（预检→后台重启→健康检查→失败回滚）
    内核零改动；不在用户机 merge lsdefine 上游（浅克隆 unrelated-histories 必炸，F-013），只跟随发行仓。"""
    flag = sys.argv[2] if len(sys.argv) > 2 else ""
    # Docker：代码在镜像里不在卷里，git pull 无意义——指向镜像升级路径
    if _in_docker():
        print(f"{WARN}容器形态：升级 = 拉取新镜像，不是 git 更新。重跑一行（数据在卷里不丢）：")
        print(f"   {DOCKER_UPDATE_HINT}")
        return 0
    print("🔄 检查蓬莱更新 ...")
    ok, behind, old, new, err = _fetch_status()
    if not ok:
        print(f"{BAD} {err}"); return 1
    if behind == 0:
        print(f"{OK} 已是最新版蓬莱。"); return 0
    logs = _changelog(old, new)
    print(f"\n  发行仓有 {behind} 个新提交（{old[:7]} → {new[:7]}）：")
    for l in logs[:12]:
        print("   • " + l)
    if flag == "--check":
        print(f"\n  确认升级请运行：penglai update --apply（或 penglai update 交互确认）")
        return 0
    if flag != "--apply":
        # 交互确认（CLI 直接跑）。非 tty 又没 --apply 则不擅自升级。
        if not (sys.stdin.isatty() and sys.stdout.isatty()):
            print(f"\n  非交互环境：确认后用 penglai update --apply 执行"); return 0
        try:
            ans = input("\n  升级并自动重启？失败会自动回滚 (y/n): ").strip().lower()
        except EOFError:
            ans = ""
        if not ans.startswith("y"):
            print("  已取消。"); return 0
    return _do_update(old, new)

def _do_update(old, new):
    if _git("status", "--porcelain").stdout.strip():
        print(f"{WARN}本地有未提交改动，可能挡住升级。");
    print("  ⬇️  拉取新版本（fast-forward）...")
    if subprocess.run(["git", "merge", "--ff-only", "origin/main"], cwd=ROOT).returncode != 0:
        print(f"{BAD} 无法 fast-forward（本地改动/历史分叉），未改动。备份 mykey 后重装即最新：\n   {REINSTALL_HINT}")
        return 1
    print("  🔍 预检新版本（编译 + 安全插件挂载）...")
    pok, detail = _preflight()
    if not pok:
        print(f"{BAD} 预检失败，已回滚，未重启服务（服务仍在旧版正常运行）：\n   {detail}")
        _git("reset", "--hard", old)
        return 1
    print(f"  {OK} 预检通过。后台监工将重启服务并健康检查，失败自动回滚——结果发到你的 IM。")
    # 派生脱离进程组的监工：它不是当前 agent/fsapp 的子进程，重启杀掉本进程也不影响它
    os.makedirs(os.path.dirname(UPDATE_LOG), exist_ok=True)
    lf = open(UPDATE_LOG, "ab")
    subprocess.Popen([venv_python(), os.path.join(ROOT, "penglai"), "_update_supervisor", old, new],
                     cwd=ROOT, stdout=lf, stderr=subprocess.STDOUT, stdin=subprocess.DEVNULL,
                     start_new_session=True)
    print(f"  已升级到 {new[:7]}，正在后台重启自检（约 1 分钟）。这条之后服务会重启，稍候我会把结果发给你。")
    return 0

def _restart_targets():
    """应处于运行态的服务（systemd）。feishu 始终在；微信/陪伴按配置。"""
    svcs = ["penglai-scheduler"]
    py = venv_python()
    fs = sh([py, "-c", "import sys;sys.path.insert(0,'.');import mykey;"
             "print(1 if getattr(mykey,'fs_app_id','') and getattr(mykey,'fs_app_secret','') else 0)"],
            cwd=ROOT).stdout.strip()
    if fs == "1":
        svcs.append("penglai-feishu")
    if os.path.exists(os.path.expanduser("~/.wxbot/token.json")):
        svcs.append("penglai-wechat")
    cp = sh([py, "-c", "import sys;sys.path.insert(0,'.');import mykey;"
             "print(1 if getattr(mykey,'companion_enabled',False) else 0)"], cwd=ROOT).stdout.strip()
    if cp == "1":
        svcs.append("penglai-companion")
    return [s for s in svcs if s in installed_services()] or ["penglai-feishu"]

def _restart(svcs):
    """无 tty 安全重启：优先免密 sudo systemctl；否则 kill 自己用户的进程靠 Restart=always 复活。"""
    if not has_systemd():
        fsapp_stop(); fsapp_start(); return
    if sh(["sudo", "-n", "systemctl", "restart", *svcs]).returncode == 0:
        return
    # 无免密 sudo：服务 User= 与本进程同用户，可直接杀；systemd Restart=always 会拉起新代码
    for pat in ("frontends/fsapp[.]py", "penglai_im_launch[.]py wechat",
                "reflect/scheduler[.]py", "reflect/penglai_companion[.]py"):
        sh(["pkill", "-f", pat])

def _channel_health():
    """返回 (ok, detail)：核心渠道服务 active 且日志见连接证据。"""
    py = venv_python()
    fs = sh([py, "-c", "import sys;sys.path.insert(0,'.');import mykey;"
             "print(1 if getattr(mykey,'fs_app_id','') and getattr(mykey,'fs_app_secret','') else 0)"],
            cwd=ROOT).stdout.strip()
    checks = []
    if fs == "1":
        checks.append(("penglai-feishu", "connected to wss"))
    if os.path.exists(os.path.expanduser("~/.wxbot/token.json")):
        checks.append(("penglai-wechat", "WeChat Bot 已启动"))
    if not checks:
        checks = [("penglai-feishu", "connected to wss")]
    bad = []
    for svc_name, pat in checks:
        active = sh(["systemctl", "is-active", svc_name]).stdout.strip() == "active" if has_systemd() else bool(fsapp_pids())
        if has_systemd():
            logtxt = sh(["journalctl", "-u", svc_name, "--since", "-3 min", "--no-pager"]).stdout
        else:
            logtxt = open(FSLOG, encoding="utf-8", errors="replace").read() if os.path.exists(FSLOG) else ""
        if not (active and pat in logtxt):
            bad.append(svc_name)
    return (not bad), (", ".join(bad) if bad else "")

def _notify_owner(text):
    """带外把升级结果发到主人 IM（飞书 + 微信），复用陪伴的发送实现。监工进程用，不依赖 agent 存活。"""
    sys.path.insert(0, ROOT)
    try:
        import mykey
    except Exception:
        return
    sent = False
    users = getattr(mykey, "fs_allowed_users", []) or []
    app_id, secret = getattr(mykey, "fs_app_id", ""), getattr(mykey, "fs_app_secret", "")
    if users and app_id:
        try:
            import reflect.penglai_companion as cp
            sent = cp._feishu_send({"open_id": users[0], "app_id": app_id, "app_secret": secret}, text) or sent
        except Exception:
            pass
    if os.path.exists(os.path.expanduser("~/.wxbot/token.json")):
        try:
            import reflect.penglai_companion as cp
            sent = cp._wechat_send(text) or sent
        except Exception:
            pass
    return sent

def update_supervisor():
    """脱离进程组的后台监工：重启 → 健康检查 → 失败 git 回滚 + 重启 → 带外回报。
    被 _do_update 以 setsid 派生，绝不是 agent/fsapp 的子进程，故重启杀掉它们不影响本进程。"""
    import time
    old = sys.argv[2] if len(sys.argv) > 2 else ""
    new = sys.argv[3] if len(sys.argv) > 3 else ""
    def log(m): print(f"[update_supervisor] {m}", flush=True)
    time.sleep(6)  # 给 agent 那条「正在升级」回复留出送达时间
    svcs = _restart_targets()
    log(f"重启服务: {svcs}")
    _restart(svcs)
    # 轮询健康（≤90s）
    healthy = False
    for _ in range(45):
        time.sleep(2)
        ok, bad = _channel_health()
        if ok:
            healthy = True; break
    if healthy:
        log("健康检查通过")
        _notify_owner(f"✅ 蓬莱已升级到 {new[:7]} 并重启完成，一切正常。")
        return 0
    # 不健康 → 回滚
    log(f"健康检查未通过（{bad}），回滚到 {old[:7]}")
    _git("reset", "--hard", old)
    _restart(svcs)
    for _ in range(45):
        time.sleep(2)
        if _channel_health()[0]:
            _notify_owner(f"⚠️ 新版本 {new[:7]} 启动失败，已自动回滚到 {old[:7]}，服务已恢复正常。"
                          f"（详情见服务器 temp/update.log）")
            return 0
    _notify_owner(f"🆘 升级到 {new[:7]} 失败且回滚后仍未恢复，请上服务器看 temp/update.log 与 penglai doctor。")
    return 1

def setup():
    return subprocess.run([sys.executable, os.path.join(ROOT, "penglai_setup.py")]).returncode

def ensure_tui_deps():
    """rich/textual 预检。uv 建的 venv 没有 pip，上游 tuiapp_v2 的
    `python -m pip` 自装必败（真机踩过），故在入口侧用 uv → ensurepip+pip 兜底。"""
    py = venv_python()
    if sh([py, "-c", "import rich, textual"]).returncode == 0:
        return True
    print("📦 首次运行，安装终端界面依赖 rich/textual ...")
    uv = shutil.which("uv") or (os.path.expanduser("~/.local/bin/uv")
                                if os.path.exists(os.path.expanduser("~/.local/bin/uv")) else None)
    attempts = []
    if uv:
        attempts.append([uv, "pip", "install", "--python", py, "-q", "rich", "textual"])
        attempts.append([uv, "pip", "install", "--python", py, "-q",
                         "-i", "https://pypi.tuna.tsinghua.edu.cn/simple", "rich", "textual"])
    attempts.append([py, "-m", "pip", "install", "-q", "rich", "textual"])
    attempts.append([py, "-m", "pip", "install", "-q",
                     "-i", "https://pypi.tuna.tsinghua.edu.cn/simple", "rich", "textual"])
    for i, cmd in enumerate(attempts):
        if cmd[1] == "-m" and sh([py, "-m", "pip", "--version"]).returncode != 0:
            sh([py, "-m", "ensurepip", "--upgrade"])
        if sh(cmd).returncode == 0 and sh([py, "-c", "import rich, textual"]).returncode == 0:
            print(f"{OK} 依赖就绪")
            return True
    print(f"{BAD} 自动安装失败，请手动执行：{py} -m pip install rich textual")
    return False

def tui():
    """终端对话界面 = 上游 GA 的 tuiapp_v2 套蓬莱品牌薄包装（内核零改动）。
    与飞书/微信共享同一份记忆——同一个管家，多个门。"""
    if not ensure_tui_deps():
        return 1
    os.chdir(ROOT)
    entry = os.path.join(ROOT, "penglai_tui.py")
    if not os.path.exists(entry):
        entry = os.path.join(ROOT, "frontends", "tuiapp_v2.py")
    os.execv(venv_python(), [venv_python(), entry])

def channel_cmd(fn_name):
    sys.path.insert(0, ROOT)
    if fn_name in ("enable", "disable"):
        name = sys.argv[2] if len(sys.argv) > 2 else ""
        import penglai_abilities as pa
        if name in pa.ABILITIES:        # 能力（语音/陪伴/情报）走能力模块
            return getattr(pa, fn_name)(name)
        import penglai_channels as pc   # 否则按渠道处理
        return getattr(pc, fn_name)(name)
    import penglai_channels as pc
    return pc.status()


def abilities():
    sys.path.insert(0, ROOT)
    import penglai_abilities as pa
    return pa.status()

def main():
    cmds = {"doctor": doctor, "status": lambda: svc("status"), "start": lambda: svc("start"),
            "stop": lambda: svc("stop"), "restart": lambda: svc("restart"),
            "logs": logs, "update": update, "setup": setup, "tui": tui,
            "channels": lambda: channel_cmd("status"), "enable": lambda: channel_cmd("enable"),
            "disable": lambda: channel_cmd("disable"), "abilities": abilities,
            "_guardcheck": guardcheck, "_update_supervisor": update_supervisor}
    arg = sys.argv[1] if len(sys.argv) > 1 else ""
    if not arg:
        # 裸跑：交互终端 → 直接进对话（对齐 hermes 体验）；管道/脚本 → 打印帮助
        if sys.stdin.isatty() and sys.stdout.isatty():
            return tui()
        print(__doc__.strip()); return 0
    if arg not in cmds:
        print(__doc__.strip()); return 0
    return cmds[arg]()

if __name__ == "__main__":
    sys.exit(main())
